{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "API_KEY",
    "OPENAI_API_KEY",
    "DODO_PAYMENTS_API_KEY",
    "TRIGGER_SECRET_KEY",
    "SMTP_USER",
    "SMTP_PASS",
    "SUPPORT_NOTIFY_EMAILS",
    "BACKEND_URL",
    "AGENT_URL",
    "NEXT_TELEMETRY_DISABLED"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
