# Copy this file to .env and fill in values for local development.
# Production values are set in .env.production (or via Vercel environment variables).

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=
API_KEY=

# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Create an OAuth 2.0 "Web application" client at:
#   https://console.cloud.google.com/apis/credentials
# Add your origins to "Authorized JavaScript origins":
#   http://localhost:3000  (local)  and  https://your-domain.com  (prod)
# Same client ID goes in both vars below (NEXT_PUBLIC_ is exposed to the browser
# and is safe to expose; GOOGLE_CLIENT_ID is read server-side to verify tokens).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ─── Database ─────────────────────────────────────────────────────────────────
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ─── PocketBase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_POCKETBASE_URL=
POCKETBASE_URL=
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Payments ─────────────────────────────────────────────────────────────────
# https://dodopayments.com
DODO_PAYMENTS_API_KEY=

# ─── Trigger.dev ──────────────────────────────────────────────────────────────
# Dev key starts with tr_dev_, prod key with tr_prod_
TRIGGER_SECRET_KEY=

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Gmail app password: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
# Comma-separated list of emails that receive support notifications
SUPPORT_NOTIFY_EMAILS=

# ─── Internal service URLs ────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8100
AGENT_URL=http://localhost:8000
